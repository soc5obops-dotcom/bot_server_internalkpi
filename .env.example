PORT=8080

# SeaTalk app credentials
SEATALK_APP_ID=
SEATALK_APP_SECRET=
SEATALK_SIGNING_SECRET=
ADMIN_TOKEN=

# Google service account JSON path mounted inside the container.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-service-account.json
# For Render, set GOOGLE_CREDENTIALS_JSON instead of mounting a file.
GOOGLE_CREDENTIALS_JSON=

# Fixed sheet settings
SHEET_ID=1pLN46ZKWJIsidswMeoxhZwoacuFMR08sCaTFG6mLytc
TAB_NAME=revamped_bot_server
WATCH_RANGE=X7:X59
CAPTURE_RANGE=F1:AD59
BOT_CONFIG_TAB=bot_config
REPORT_LINK=https://docs.google.com/spreadsheets/d/1fz0N-8-BWs_6ub4UzfKhBdLIjlRpwc94p4DJHNB6SvU/edit?gid=1887496356#gid=1887496356
APP_TIMEZONE=Asia/Manila

# Polling/debounce
ENABLE_SHEET_POLLING=true
ENABLE_SCHEDULED_SENDS=true
POLL_INTERVAL=5m
SETTLE_INTERVAL=10s

# Output: png or jpg. SeaTalk image payload must stay below 5 MB after base64.
IMAGE_FORMAT=png
PNG_DPI=180
PNG_MAX_WIDTH=1600
WORK_DIR=/app/tmp
